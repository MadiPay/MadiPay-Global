<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MadiPay Global - Elite Smart Router</title>
    <style>
        /* --- الهوية البصرية السيادية (Cyber-Style & Glassmorphism) --- */
        :root {
            --bg-charcoal: #12161A;
            --accent-orange: #FF6B00;
            --accent-green: #00E676;
            --text-white: #FFFFFF;
            --text-muted: #8A99AD;
            --glass-bg: rgba(25, 32, 40, 0.65);
            --glass-border: rgba(255, 107, 0, 0.15);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: var(--bg-charcoal);
            color: var(--text-white);
            min-height: 100vh;
            padding: 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .app-container {
            width: 100%;
            max-width: 480px;
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
        }

        .header {
            text-align: center;
            margin-bottom: 28px;
        }

        .header h1 {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--text-white);
        }

        .header h1 span {
            color: var(--accent-orange);
        }

        .header p {
            color: var(--text-muted);
            font-size: 12px;
            margin-top: 6px;
            line-height: 1.6;
        }

        .wallet-card {
            background: linear-gradient(135deg, rgba(255, 107, 0, 0.1), rgba(0, 230, 118, 0.05));
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 24px;
            position: relative;
            overflow: hidden;
        }

        .wallet-label {
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .wallet-balance {
            font-size: 32px;
            font-weight: 700;
            color: var(--text-white);
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .wallet-balance span {
            color: var(--accent-green);
            font-size: 18px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        .form-group label {
            display: block;
            font-size: 13px;
            color: var(--text-muted);
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-control {
            width: 100%;
            background: rgba(10, 14, 18, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 16px;
            color: var(--text-white);
            font-size: 16px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            outline: none;
            border-color: var(--accent-orange);
            box-shadow: 0 0 10px rgba(255, 107, 0, 0.2);
        }

        select.form-control {
            cursor: pointer;
        }

        .btn-submit {
            width: 100%;
            background: var(--accent-orange);
            color: var(--text-white);
            border: none;
            border-radius: 12px;
            padding: 15px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            box-shadow: 0 4px 15px rgba(255, 107, 0, 0.3);
        }

        .btn-submit:hover {
            background: #e05e00;
        }

        .routing-status {
            margin-top: 24px;
            background: rgba(10, 14, 18, 0.5);
            border-radius: 14px;
            padding: 16px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            display: none;
        }

        .status-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding-bottom: 10px;
            margin-bottom: 12px;
        }

        .status-title {
            font-size: 13px;
            font-weight: 600;
            color: var(--accent-green);
        }

        .badge {
            background: rgba(0, 230, 118, 0.15);
            color: var(--accent-green);
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: bold;
        }

        .data-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            margin-bottom: 8px;
        }

        .data-row .label {
            color: var(--text-muted);
        }

        .data-row .value {
            color: var(--text-white);
            font-weight: 500;
        }

        .ledger-section {
            margin-top: 24px;
        }

        .ledger-title {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 12px;
            font-weight: 600;
        }

        .ledger-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 10px;
            padding: 12px;
            margin-bottom: 8px;
            font-size: 12px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .ledger-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .ledger-amount {
            font-weight: bold;
            color: var(--accent-green);
        }
    </style>
</head>
<body>

    <div class="app-container">
        <div class="header">
            <h1>MadiPay <span>Global</span></h1>
            <p>منصة ذكية متطورة لإدارة وتوجيه المدفوعات الرقمية وبوابات الدفع المحصنة</p>
        </div>

        <div class="wallet-card">
            <div class="wallet-label">الرصيد المتوفر في المحفظة السيادية</div>
            <div class="wallet-balance" id="walletBalance">0.00 <span>MadiCoin</span></div>
        </div>

        <div class="form-group">
            <label for="marketSelect">سوق التوجيه الذكي (التحليل المزدوج)</label>
            <select id="marketSelect" class="form-control" onchange="MadiRouter.updateMarketRates()">
                <option value="official">السوق الرسمي المعياري (Official Bank Rates)</option>
                <option value="parallel">السوق الموازي المرن (Parallel Liquidity Market)</option>
            </select>
        </div>

        <div class="form-group">
            <label for="amountInput">المبلغ المراد توجيهه وتأمينه</label>
            <input type="number" id="amountInput" class="form-control" placeholder="أدخل قيمة المبلغ..." min="1" oninput="MadiRouter.updateMarketRates()">
        </div>

        <button class="btn-submit" onclick="MadiRouter.executeRoute()">تفعيل التوجيه والضمان المستقل</button>

        <div class="routing-status" id="routingStatusBox">
            <div class="status-header">
                <span class="status-title">⚡ محرك التوجيه الفوري (Vortex Core)</span>
                <span class="badge" id="statusBadge">نشط ومعتمد</span>
            </div>
            <div class="data-row">
                <span class="label">السعر المحتسب للوحدة:</span>
                <span class="value" id="calculatedRate">0.00</span>
            </div>
            <div class="data-row">
                <span class="label">صافي القيمة بعد المعالجة:</span>
                <span class="value" id="netValue">0.00</span>
            </div>
            <div class="data-row">
                <span class="label">بروتوكول حجز السيولة (Escrow Lock):</span>
                <span class="value" id="escrowLockStatus" style="color: #FF6B00; font-weight: bold;">قيد الانتظار</span>
            </div>
        </div>

        <div class="ledger-section">
            <div class="ledger-title">سجل المعاملات المحصن (Immutable Logs)</div>
            <div id="ledgerLogs"></div>
        </div>
    </div>

    <script>
        const MadiRouter = {
            rates: {
                official: 1.00,
                parallel: 1.45
            },
            
            init: function() {
                if (!localStorage.getItem('madi_balance')) {
                    localStorage.setItem('madi_balance', '5000.00');
                }
                if (!localStorage.getItem('madi_ledger')) {
                    localStorage.setItem('madi_ledger', JSON.stringify([]));
                }
                this.renderUI();
            },

            renderUI: function() {
                const balance = parseFloat(localStorage.getItem('madi_balance')).toFixed(2);
                document.getElementById('walletBalance').innerHTML = balance + ' <span style="color: #00E676; font-size: 18px;">MadiCoin</span>';
                this.renderLedger();
            },

            updateMarketRates: function() {
                const market = document.getElementById('marketSelect').value;
                const rate = this.rates[market];
                const amount = parseFloat(document.getElementById('amountInput').value) || 0;
                
                if(amount > 0) {
                    document.getElementById('routingStatusBox').style.display = 'block';
                    document.getElementById('calculatedRate').innerText = rate.toFixed(2) + ' لكل وحدة';
                    document.getElementById('netValue').innerText = (amount * rate).toFixed(2) + ' MadiCoin';
                } else {
                    document.getElementById('routingStatusBox').style.display = 'none';
                }
            },

            executeRoute: function() {
                const amount = parseFloat(document.getElementById('amountInput').value);
                const market = document.getElementById('marketSelect').value;
                let currentBalance = parseFloat(localStorage.getItem('madi_balance'));

                if (isNaN(amount) || amount <= 0) {
                    alert('خطأ: يرجى إدخال مبلغ صحيح وصالح للمعالجة.');
                    return;
                }

                if (amount > currentBalance) {
                    alert('خطأ الأمن المالي: الرصيد الحالي غير كافٍ لإتمام حجز السيولة.');
                    return;
                }

                const rate = this.rates[market];
                const finalNet = amount * rate;
                
                currentBalance -= amount;
                localStorage.setItem('madi_balance', currentBalance.toString());

                const ledger = JSON.parse(localStorage.getItem('madi_ledger'));
                const newTransaction = {
                    id: 'TXN-' + Math.floor(100000 + Math.random() * 900000),
                    date: new Date().toLocaleTimeString('ar-EG'),
                    market: market === 'official' ? 'رسمي' : 'موازي',
                    amount: amount.toFixed(2),
                    net: finalNet.toFixed(2)
                };
                
                ledger.unshift(newTransaction);
                localStorage.setItem('madi_ledger', JSON.stringify(ledger));

                document.getElementById('routingStatusBox').style.display = 'block';
                document.getElementById('calculatedRate').innerText = rate.toFixed(2);
                document.getElementById('netValue').innerText = finalNet.toFixed(2) + ' MadiCoin';
                
                const escrowStatus = document.getElementById('escrowLockStatus');
                escrowStatus.innerText = 'تم التوجيه والحجز بنجاح (Locked)';
                escrowStatus.style.color = '#00E676';

                document.getElementById('amountInput').value = '';
                this.renderUI();
            },

            renderLedger: function() {
                const ledger = JSON.parse(localStorage.getItem('madi_ledger'));
                const container = document.getElementById('ledgerLogs');
                container.innerHTML = '';

                if (ledger.length === 0) {
                    container.innerHTML = '<div class="ledger-item" style="color: #8A99AD; text-align:center; display:block;">لا توجد معاملات مسجلة حتى الآن.</div>';
                    return;
                }

                ledger.forEach(function(txn) {
                    const item = document.createElement('div');
                    item.className = 'ledger-item';
                    item.innerHTML = `
                        <div class="ledger-info">
                            <span style="font-weight:600; color:#FFFFFF;">${txn.id} | سوق ${txn.market}</span>
                            <span style="color:#8A99AD; font-size:10px;">الوقت: ${txn.date}</span>
                        </div>
                        <div class="ledger-amount">+${txn.net} MC</div>
                    `;
                    container.appendChild(item);
                });
            }
        };

        window.onload = function() {
            MadiRouter.init();
        };
    </script>
</body>
</html>
