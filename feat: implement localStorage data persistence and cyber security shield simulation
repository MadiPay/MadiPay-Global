<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MadiPay Global | منصة التوجيه الذكي</title>
    <style>
        /* --- العودة إلى الهوية البصرية النخبوية والألوان الاستراتيجية --- */
        :root {
            --bg-charcoal: #12161A;       /* الرمادي الفاخر */
            --neon-orange: #FF6B00;       /* البرتقالي الحيوي */
            --emerald-green: #00E676;     /* الأخضر الزمردي */
            --glass-bg: rgba(25, 30, 36, 0.65); 
            --glass-border: rgba(255, 255, 255, 0.05);
            --text-main: #FFFFFF;
            --text-muted: #8A99AD;
            --warning-amber: #FFB300;     
            --danger-red: #FF3D00;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-charcoal);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 15px;
            overflow-x: hidden;
        }

        .vortex-container {
            width: 100%;
            max-width: 480px;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            margin-top: 10px;
        }

        .brand-header {
            text-align: center;
            margin-bottom: 20px;
        }

        .brand-header h1 {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 1px;
            background: linear-gradient(135deg, var(--text-main), var(--text-muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .brand-header span {
            color: var(--neon-orange);
        }

        .badge-router {
            display: inline-block;
            font-size: 0.75rem;
            background: rgba(0, 230, 118, 0.1);
            color: var(--emerald-green);
            padding: 4px 12px;
            border-radius: 12px;
            margin-top: 6px;
            border: 1px solid rgba(0, 230, 118, 0.2);
            font-weight: bold;
        }

        /* --- نظام المحفظة المزدوج --- */
        .wallet-card {
            background: linear-gradient(135deg, rgba(255, 107, 0, 0.08), rgba(0, 230, 118, 0.04));
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 16px;
            padding: 14px;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .wallet-info .wallet-label, .escrow-info .escrow-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            display: block;
            margin-bottom: 4px;
        }

        .wallet-info .wallet-balance {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--emerald-green);
        }

        .escrow-info {
            text-align: left;
        }

        .escrow-info .escrow-balance {
            font-size: 1.2rem;
            font-weight: 800;
            color: var(--warning-amber);
        }

        /* --- مفتاح التبديل الاستراتيجي --- */
        .market-selector {
            display: flex;
            background: rgba(0, 0, 0, 0.4);
            border-radius: 14px;
            padding: 4px;
            margin-bottom: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .market-btn {
            flex: 1;
            padding: 10px;
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.3s ease;
        }

        .market-btn.active {
            background: var(--neon-orange);
            color: var(--text-main);
            box-shadow: 0 4px 12px rgba(255, 107, 0, 0.3);
        }

        /* --- لوحة الرصد ومؤشر التقلبات الحية --- */
        .volatility-panel {
            background: rgba(0, 0, 0, 0.25);
            border-radius: 12px;
            padding: 10px 14px;
            margin-bottom: 16px;
            font-size: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }
        .volatility-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
            color: var(--text-muted);
        }
        .volatility-bar-bg {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 4px;
            overflow: hidden;
        }
        .volatility-bar-fill {
            height: 100%;
            width: 20%;
            background: var(--emerald-green);
            transition: all 0.5s ease;
        }

        /* --- عناصر الإدخال الحيوية --- */
        .input-group {
            margin-bottom: 14px;
        }

        .input-group label {
            display: block;
            font-size: 0.8rem;
            color: var(--text-muted);
            margin-bottom: 6px;
        }

        .input-wrapper input, .input-wrapper select {
            width: 100%;
            padding: 12px 14px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            color: var(--text-main);
            font-size: 0.95rem;
            font-weight: 600;
            outline: none;
        }

        /* --- لوحة مخرجات الخوارزمية الذكية --- */
        .router-output {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
            padding: 14px;
            margin-bottom: 16px;
            border: 1px dashed rgba(255, 255, 255, 0.1);
        }

        .output-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 8px;
            font-size: 0.85rem;
        }

        .output-row:last-child {
            margin-bottom: 0;
            padding-top: 8px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        .output-label {
            color: var(--text-muted);
        }

        .output-value {
            font-weight: 700;
        }

        .output-value.highlight {
            color: var(--emerald-green);
        }

        /* --- لوحة حماية الضمان المعلق --- */
        .escrow-actions-panel {
            background: rgba(255, 179, 0, 0.05);
            border: 1px solid rgba(255, 179, 0, 0.15);
            border-radius: 14px;
            padding: 12px;
            margin-bottom: 16px;
            display: none; 
            text-align: center;
        }

        .escrow-actions-panel p {
            font-size: 0.8rem;
            color: var(--warning-amber);
            margin-bottom: 10px;
            font-weight: 600;
        }

        .btn-group {
            display: flex;
            gap: 10px;
        }

        .btn-sub {
            flex: 1;
            padding: 10px;
            border: none;
            border-radius: 8px;
            font-size: 0.85rem;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-release {
            background: var(--emerald-green);
            color: #000;
        }

        .btn-cancel {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-main);
        }

        .btn-execute {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, var(--neon-orange), #FF8800);
            border: none;
            border-radius: 12px;
            color: var(--text-main);
            font-size: 1.05rem;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(255, 107, 0, 0.4);
            margin-bottom: 24px;
        }

        /* --- سجل العمليات التاريخي المدقق (Ledger) --- */
        .ledger-section {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 16px;
        }

        .ledger-title {
            font-size: 0.9rem;
            color: var(--text-main);
            margin-bottom: 12px;
            font-weight: 700;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .ledger-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 180px;
            overflow-y: auto;
            padding-right: 4px;
        }

        .ledger-item {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 10px;
            padding: 10px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
        }

        .ledger-meta {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .ledger-meta .tx-market {
            font-size: 0.7rem;
            color: var(--text-muted);
        }

        .ledger-amount {
            font-weight: 700;
            text-align: left;
        }

        .status-badge {
            font-size: 0.65rem;
            padding: 2px 6px;
            border-radius: 6px;
            font-weight: bold;
            display: inline-block;
            margin-top: 2px;
        }

        .status-hold { background: rgba(255, 179, 0, 0.15); color: var(--warning-amber); }
        .status-success { background: rgba(0, 230, 118, 0.15); color: var(--emerald-green); }
        .status-rejected { background: rgba(255, 61, 0, 0.15); color: var(--danger-red); }
        
        .btn-clear-storage {
            background: transparent;
            border: none;
            color: var(--text-muted);
            font-size: 0.7rem;
            cursor: pointer;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="vortex-container">
        <div class="brand-header">
            <h1>Madi<span>Pay</span> Global</h1>
            <div class="badge-router">بوابة التوجيه وحماية السيولة المستدامة</div>
        </div>

        <div class="wallet-card">
            <div class="wallet-info">
                <span class="wallet-label">الرصيد المفرج عنه</span>
                <span class="wallet-balance" id="wallet-total">0.00 د.ج</span>
            </div>
            <div class="escrow-info">
                <span class="escrow-label">السيولة المعلقة (الضمان)</span>
                <span class="escrow-balance" id="escrow-total">0.00 د.ج</span>
            </div>
        </div>

        <div class="market-selector">
            <button class="market-btn active" id="btn-official" onclick="setMarket('official')">السعر الرسمي (البنك)</button>
            <button class="market-btn" id="btn-parallel" onclick="setMarket('parallel')">السوق الموازي (السكوار)</button>
        </div>

        <div class="volatility-panel">
            <div class="volatility-header">
                <span>مؤشر تقلبات السيولة المخفية: <strong id="vol-txt">منخفض (مستقر)</strong></span>
                <span>عمولة التوجيه الذكية: <strong id="fee-txt">0.5%</strong></span>
            </div>
            <div class="volatility-bar-bg">
                <div class="volatility-bar-fill" id="vol-bar"></div>
            </div>
        </div>

        <div class="input-group">
            <label for="amount">المبلغ بالعملة الأجنبية</label>
            <div class="input-wrapper">
                <input type="number" id="amount" value="1000" oninput="calculateRouting()">
            </div>
        </div>

        <div class="input-group">
            <label for="currency">العملة الواردة</label>
            <div class="input-wrapper">
                <select id="currency" onchange="calculateRouting()">
                    <option value="EUR">اليورو (€)</option>
                    <option value="USD">الدولار الأمريكي ($)</option>
                    <option value="GBP">الجنيه الإسترليني (£)</option>
                </select>
            </div>
        </div>

        <div class="router-output">
            <div class="output-row">
                <span class="output-label">معدل الصرف الخام:</span>
                <span class="output-value" id="rate-display">1 يورو = 150.00 د.ج</span>
            </div>
            <div class="output-row">
                <span class="output-label">الرسوم المستقطعة:</span>
                <span class="output-value" id="fee-display" style="color: var(--danger-red);">0.00 د.ج</span>
            </div>
            <div class="output-row">
                <span class="output-label">صافي القيمة النهائية للتوجيه:</span>
                <span class="output-value highlight" id="total-display">150,000.00 د.ج</span>
            </div>
        </div>

        <div class="escrow-actions-panel" id="escrow-panel">
            <p>🛡️ معاملة قيد الحماية المعلقة: <span id="current-pending-txt">0.00 د.ج</span></p>
            <div class="btn-group">
                <button class="btn-sub btn-release" onclick="releaseEscrow()">إفراج ونقل للمحفظة</button>
                <button class="btn-sub btn-cancel" onclick="cancelEscrow()">إلغاء واسترداد</button>
            </div>
        </div>

        <button class="btn-execute" id="btn-main-action" onclick="initiateSecureTransaction()">بدء معاملة مشفرة معلقة</button>

        <div class="ledger-section">
            <div class="ledger-title">
                <span>سجل التدفقات الماليّة المدققة</span>
                <button class="btn-clear-storage" onclick="clearSavedData()">تصفية السجل</button>
            </div>
            <div class="ledger-list" id="ledger-container"></div>
        </div>
    </div>

    <script src="assets/js/main.js"></script>
</body>
</html>
